{
  "info": {
    "name": "DocuHog - DocuSign Mock API",
    "description": "Complete collection for testing DocuHog, a MailHog-style mock server for the DocuSign eSignature REST API.\n\nRun requests in order — the \"Auth\" folder first, then work through the scenarios.\n\nVariables like {{envelopeId}} and {{templateId}} are auto-set by test scripts when you create resources.",
    "schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json"
  },
  "variable": [
    { "key": "baseUrl", "value": "http://localhost:8025", "type": "string" },
    { "key": "accountId", "value": "12345678-abcd-1234-efgh-123456789012", "type": "string" },
    { "key": "accessToken", "value": "", "type": "string" },
    { "key": "envelopeId", "value": "", "type": "string" },
    { "key": "draftEnvelopeId", "value": "", "type": "string" },
    { "key": "templateId", "value": "", "type": "string" }
  ],
  "item": [
    {
      "name": "1. Auth",
      "description": "Get an access token. Run this first.",
      "item": [
        {
          "name": "Get Access Token",
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "const json = pm.response.json();",
                  "pm.test('Returns access token', () => {",
                  "  pm.expect(json.access_token).to.be.a('string');",
                  "  pm.expect(json.token_type).to.eql('Bearer');",
                  "  pm.expect(json.expires_in).to.eql(3600);",
                  "});",
                  "pm.collectionVariables.set('accessToken', json.access_token);"
                ]
              }
            }
          ],
          "request": {
            "method": "POST",
            "header": [],
            "body": {
              "mode": "urlencoded",
              "urlencoded": [
                { "key": "grant_type", "value": "authorization_code" },
                { "key": "code", "value": "mock-auth-code" },
                { "key": "client_id", "value": "my-integration-key" }
              ]
            },
            "url": "{{baseUrl}}/oauth/token"
          }
        },
        {
          "name": "Get Access Token (JWT Grant)",
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "const json = pm.response.json();",
                  "pm.test('Returns access token for JWT grant', () => {",
                  "  pm.expect(json.access_token).to.be.a('string');",
                  "  pm.expect(json.token_type).to.eql('Bearer');",
                  "});"
                ]
              }
            }
          ],
          "request": {
            "method": "POST",
            "header": [],
            "body": {
              "mode": "urlencoded",
              "urlencoded": [
                { "key": "grant_type", "value": "urn:ietf:params:oauth:grant-type:jwt-bearer" },
                { "key": "assertion", "value": "mock-jwt-assertion" }
              ]
            },
            "url": "{{baseUrl}}/oauth/token"
          }
        },
        {
          "name": "Get User Info",
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "const json = pm.response.json();",
                  "pm.test('Returns user info with accounts', () => {",
                  "  pm.expect(json.name).to.eql('DocuHog User');",
                  "  pm.expect(json.email).to.eql('user@docuhog.local');",
                  "  pm.expect(json.accounts).to.be.an('array');",
                  "  pm.expect(json.accounts[0].account_id).to.be.a('string');",
                  "});"
                ]
              }
            }
          ],
          "request": {
            "method": "GET",
            "header": [],
            "url": "{{baseUrl}}/oauth/userinfo"
          }
        }
      ]
    },
    {
      "name": "2. Account Info",
      "description": "Account and login information endpoints.",
      "item": [
        {
          "name": "Get Account Info",
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "const json = pm.response.json();",
                  "pm.test('Returns account info', () => {",
                  "  pm.expect(json.accountId).to.be.a('string');",
                  "  pm.expect(json.accountName).to.eql('DocuHog Test Account');",
                  "  pm.expect(json.planName).to.eql('DocuHog Mock Plan');",
                  "});"
                ]
              }
            }
          ],
          "request": {
            "method": "GET",
            "header": [
              { "key": "Authorization", "value": "Bearer {{accessToken}}" }
            ],
            "url": "{{baseUrl}}/restapi/v2.1/accounts/{{accountId}}"
          }
        },
        {
          "name": "Get Login Information (Legacy)",
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "const json = pm.response.json();",
                  "pm.test('Returns login accounts', () => {",
                  "  pm.expect(json.loginAccounts).to.be.an('array');",
                  "  pm.expect(json.loginAccounts[0].name).to.eql('DocuHog Test Account');",
                  "});"
                ]
              }
            }
          ],
          "request": {
            "method": "GET",
            "header": [
              { "key": "Authorization", "value": "Bearer {{accessToken}}" }
            ],
            "url": "{{baseUrl}}/restapi/v2.1/login_information"
          }
        }
      ]
    },
    {
      "name": "3. Envelopes - Full Lifecycle",
      "description": "Create, send, list, update, void envelopes.",
      "item": [
        {
          "name": "Create Envelope (Send Immediately)",
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "const json = pm.response.json();",
                  "pm.test('Status 201 - Envelope created', () => {",
                  "  pm.response.to.have.status(201);",
                  "});",
                  "pm.test('Returns envelope ID and sent status', () => {",
                  "  pm.expect(json.envelopeId).to.be.a('string');",
                  "  pm.expect(json.status).to.eql('sent');",
                  "});",
                  "pm.collectionVariables.set('envelopeId', json.envelopeId);"
                ]
              }
            }
          ],
          "request": {
            "method": "POST",
            "header": [
              { "key": "Authorization", "value": "Bearer {{accessToken}}" },
              { "key": "Content-Type", "value": "application/json" }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"emailSubject\": \"Please sign: Consulting Agreement\",\n  \"emailBlurb\": \"Please review and sign this consulting agreement at your earliest convenience.\",\n  \"status\": \"sent\",\n  \"recipients\": {\n    \"signers\": [\n      {\n        \"email\": \"alice@example.com\",\n        \"name\": \"Alice Johnson\",\n        \"recipientId\": \"1\",\n        \"routingOrder\": \"1\",\n        \"tabs\": {\n          \"signHereTabs\": [\n            {\n              \"documentId\": \"1\",\n              \"pageNumber\": \"1\",\n              \"xPosition\": \"200\",\n              \"yPosition\": \"400\"\n            }\n          ],\n          \"dateSignedTabs\": [\n            {\n              \"documentId\": \"1\",\n              \"pageNumber\": \"1\",\n              \"xPosition\": \"200\",\n              \"yPosition\": \"450\"\n            }\n          ]\n        }\n      },\n      {\n        \"email\": \"bob@example.com\",\n        \"name\": \"Bob Williams\",\n        \"recipientId\": \"2\",\n        \"routingOrder\": \"2\"\n      }\n    ],\n    \"carbonCopies\": [\n      {\n        \"email\": \"legal@example.com\",\n        \"name\": \"Legal Department\",\n        \"recipientId\": \"3\",\n        \"routingOrder\": \"3\"\n      }\n    ]\n  },\n  \"documents\": [\n    {\n      \"documentId\": \"1\",\n      \"name\": \"Consulting Agreement\",\n      \"fileExtension\": \"pdf\",\n      \"order\": \"1\"\n    },\n    {\n      \"documentId\": \"2\",\n      \"name\": \"Exhibit A - Statement of Work\",\n      \"fileExtension\": \"pdf\",\n      \"order\": \"2\"\n    }\n  ]\n}"
            },
            "url": "{{baseUrl}}/restapi/v2.1/accounts/{{accountId}}/envelopes"
          }
        },
        {
          "name": "Create Draft Envelope",
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "const json = pm.response.json();",
                  "pm.test('Status 201 - Draft created', () => {",
                  "  pm.response.to.have.status(201);",
                  "});",
                  "pm.test('Returns created (draft) status', () => {",
                  "  pm.expect(json.envelopeId).to.be.a('string');",
                  "  pm.expect(json.status).to.eql('created');",
                  "});",
                  "pm.collectionVariables.set('draftEnvelopeId', json.envelopeId);"
                ]
              }
            }
          ],
          "request": {
            "method": "POST",
            "header": [
              { "key": "Authorization", "value": "Bearer {{accessToken}}" },
              { "key": "Content-Type", "value": "application/json" }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"emailSubject\": \"DRAFT: Employment Offer Letter\",\n  \"emailBlurb\": \"This is a draft offer letter for review.\",\n  \"status\": \"created\",\n  \"recipients\": {\n    \"signers\": [\n      {\n        \"email\": \"candidate@example.com\",\n        \"name\": \"Jane Candidate\",\n        \"recipientId\": \"1\",\n        \"routingOrder\": \"1\"\n      }\n    ]\n  },\n  \"documents\": [\n    {\n      \"documentId\": \"1\",\n      \"name\": \"Offer Letter\",\n      \"fileExtension\": \"pdf\"\n    }\n  ]\n}"
            },
            "url": "{{baseUrl}}/restapi/v2.1/accounts/{{accountId}}/envelopes"
          }
        },
        {
          "name": "Send Draft Envelope",
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "const json = pm.response.json();",
                  "pm.test('Envelope status changed to sent', () => {",
                  "  pm.expect(json.status).to.eql('sent');",
                  "  pm.expect(json.envelopeId).to.eql(pm.collectionVariables.get('draftEnvelopeId'));",
                  "});"
                ]
              }
            }
          ],
          "request": {
            "method": "PUT",
            "header": [
              { "key": "Authorization", "value": "Bearer {{accessToken}}" },
              { "key": "Content-Type", "value": "application/json" }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"status\": \"sent\"\n}"
            },
            "url": "{{baseUrl}}/restapi/v2.1/accounts/{{accountId}}/envelopes/{{draftEnvelopeId}}"
          }
        },
        {
          "name": "List All Envelopes",
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "const json = pm.response.json();",
                  "pm.test('Returns envelope list', () => {",
                  "  pm.expect(parseInt(json.totalSetSize)).to.be.greaterThan(0);",
                  "  pm.expect(json.envelopes).to.be.an('array');",
                  "});"
                ]
              }
            }
          ],
          "request": {
            "method": "GET",
            "header": [
              { "key": "Authorization", "value": "Bearer {{accessToken}}" }
            ],
            "url": {
              "raw": "{{baseUrl}}/restapi/v2.1/accounts/{{accountId}}/envelopes?from_date=2020-01-01",
              "host": ["{{baseUrl}}"],
              "path": ["restapi", "v2.1", "accounts", "{{accountId}}", "envelopes"],
              "query": [
                { "key": "from_date", "value": "2020-01-01" }
              ]
            }
          }
        },
        {
          "name": "List Envelopes (Status Filter)",
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "const json = pm.response.json();",
                  "pm.test('Returns only sent envelopes', () => {",
                  "  if (json.envelopes) {",
                  "    json.envelopes.forEach(e => {",
                  "      pm.expect(e.status).to.eql('sent');",
                  "    });",
                  "  }",
                  "});"
                ]
              }
            }
          ],
          "request": {
            "method": "GET",
            "header": [
              { "key": "Authorization", "value": "Bearer {{accessToken}}" }
            ],
            "url": {
              "raw": "{{baseUrl}}/restapi/v2.1/accounts/{{accountId}}/envelopes?from_date=2020-01-01&status=sent",
              "host": ["{{baseUrl}}"],
              "path": ["restapi", "v2.1", "accounts", "{{accountId}}", "envelopes"],
              "query": [
                { "key": "from_date", "value": "2020-01-01" },
                { "key": "status", "value": "sent" }
              ]
            }
          }
        },
        {
          "name": "List Envelopes (Search Text)",
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "const json = pm.response.json();",
                  "pm.test('Search returns matching envelopes', () => {",
                  "  pm.response.to.have.status(200);",
                  "});"
                ]
              }
            }
          ],
          "request": {
            "method": "GET",
            "header": [
              { "key": "Authorization", "value": "Bearer {{accessToken}}" }
            ],
            "url": {
              "raw": "{{baseUrl}}/restapi/v2.1/accounts/{{accountId}}/envelopes?from_date=2020-01-01&search_text=Consulting",
              "host": ["{{baseUrl}}"],
              "path": ["restapi", "v2.1", "accounts", "{{accountId}}", "envelopes"],
              "query": [
                { "key": "from_date", "value": "2020-01-01" },
                { "key": "search_text", "value": "Consulting" }
              ]
            }
          }
        },
        {
          "name": "Get Envelope",
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "const json = pm.response.json();",
                  "pm.test('Returns full envelope details', () => {",
                  "  pm.expect(json.envelopeId).to.eql(pm.collectionVariables.get('envelopeId'));",
                  "  pm.expect(json.emailSubject).to.be.a('string');",
                  "  pm.expect(json.status).to.be.a('string');",
                  "  pm.expect(json.createdDateTime).to.be.a('string');",
                  "});"
                ]
              }
            }
          ],
          "request": {
            "method": "GET",
            "header": [
              { "key": "Authorization", "value": "Bearer {{accessToken}}" }
            ],
            "url": "{{baseUrl}}/restapi/v2.1/accounts/{{accountId}}/envelopes/{{envelopeId}}"
          }
        },
        {
          "name": "Update Envelope (Change Subject)",
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "const json = pm.response.json();",
                  "pm.test('Envelope updated', () => {",
                  "  pm.response.to.have.status(200);",
                  "  pm.expect(json.envelopeId).to.be.a('string');",
                  "});"
                ]
              }
            }
          ],
          "request": {
            "method": "PUT",
            "header": [
              { "key": "Authorization", "value": "Bearer {{accessToken}}" },
              { "key": "Content-Type", "value": "application/json" }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"emailSubject\": \"UPDATED: Please sign - Consulting Agreement\",\n  \"emailBlurb\": \"Updated blurb text\"\n}"
            },
            "url": "{{baseUrl}}/restapi/v2.1/accounts/{{accountId}}/envelopes/{{envelopeId}}"
          }
        },
        {
          "name": "Void Envelope",
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "const json = pm.response.json();",
                  "pm.test('Envelope voided', () => {",
                  "  pm.expect(json.status).to.eql('voided');",
                  "});"
                ]
              }
            }
          ],
          "request": {
            "method": "PUT",
            "header": [
              { "key": "Authorization", "value": "Bearer {{accessToken}}" },
              { "key": "Content-Type", "value": "application/json" }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"status\": \"voided\",\n  \"voidedReason\": \"Contract terms changed — new version will be sent.\"\n}"
            },
            "url": "{{baseUrl}}/restapi/v2.1/accounts/{{accountId}}/envelopes/{{envelopeId}}"
          }
        },
        {
          "name": "Get Envelope (Not Found)",
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "pm.test('Returns 404', () => {",
                  "  pm.response.to.have.status(404);",
                  "});",
                  "pm.test('Returns error body', () => {",
                  "  const json = pm.response.json();",
                  "  pm.expect(json.errorCode).to.eql('ENVELOPE_DOES_NOT_EXIST');",
                  "});"
                ]
              }
            }
          ],
          "request": {
            "method": "GET",
            "header": [
              { "key": "Authorization", "value": "Bearer {{accessToken}}" }
            ],
            "url": "{{baseUrl}}/restapi/v2.1/accounts/{{accountId}}/envelopes/nonexistent-id"
          }
        }
      ]
    },
    {
      "name": "4. Recipients",
      "description": "Get and update envelope recipients.",
      "item": [
        {
          "name": "Get Recipients",
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "const json = pm.response.json();",
                  "pm.test('Returns recipients', () => {",
                  "  pm.expect(json.signers || json.recipientCount).to.exist;",
                  "});"
                ]
              }
            }
          ],
          "request": {
            "method": "GET",
            "header": [
              { "key": "Authorization", "value": "Bearer {{accessToken}}" }
            ],
            "url": "{{baseUrl}}/restapi/v2.1/accounts/{{accountId}}/envelopes/{{draftEnvelopeId}}/recipients"
          }
        },
        {
          "name": "Update Recipients (Add Signer)",
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "const json = pm.response.json();",
                  "pm.test('Recipients updated', () => {",
                  "  pm.response.to.have.status(200);",
                  "  pm.expect(json.signers).to.be.an('array');",
                  "});"
                ]
              }
            }
          ],
          "request": {
            "method": "PUT",
            "header": [
              { "key": "Authorization", "value": "Bearer {{accessToken}}" },
              { "key": "Content-Type", "value": "application/json" }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"signers\": [\n    {\n      \"email\": \"new-signer@example.com\",\n      \"name\": \"New Signer\",\n      \"recipientId\": \"10\",\n      \"routingOrder\": \"5\"\n    }\n  ]\n}"
            },
            "url": "{{baseUrl}}/restapi/v2.1/accounts/{{accountId}}/envelopes/{{draftEnvelopeId}}/recipients"
          }
        }
      ]
    },
    {
      "name": "5. Documents",
      "description": "List and download envelope documents.",
      "item": [
        {
          "name": "List Documents",
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "const json = pm.response.json();",

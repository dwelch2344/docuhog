            "url": "{{baseUrl}}/restapi/v2.1/accounts/{{accountId}}/envelopes/{{draftEnvelopeId}}/documents/1"
          }
        }
      ]
    },
    {
      "name": "6. Views",
      "description": "Create recipient and sender signing/sending views.",
      "item": [
        {
          "name": "Create Recipient View (Signing URL)",
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "const json = pm.response.json();",
                  "pm.test('Returns signing URL', () => {",
                  "  pm.response.to.have.status(201);",

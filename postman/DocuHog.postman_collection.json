                  "});"
                ]
              }
            }
          ],
          "request": {
            "method": "GET",
            "header": [
              { "key": "Authorization", "value": "Bearer {{accessToken}}" }
            ],
            "url": "{{baseUrl}}/restapi/v2.1/accounts/{{accountId}}/envelopes/{{draftEnvelopeId}}/documents"
          }

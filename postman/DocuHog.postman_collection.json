            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"returnUrl\": \"http://localhost:3000/sending/complete\"\n}"
            },
            "url": "{{baseUrl}}/restapi/v2.1/accounts/{{accountId}}/envelopes/{{draftEnvelopeId}}/views/sender"
          }
        }
      ]
    },
    {
      "name": "7. Audit & Notifications",
      "description": "Envelope audit events and notification settings.",
      "item": [
        {
          "name": "Get Audit Events",
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "const json = pm.response.json();",
                  "pm.test('Returns audit events', () => {",
                  "  pm.expect(json.auditEvents).to.be.an('array');",
                  "  pm.expect(json.auditEvents.length).to.be.greaterThan(0);",
                  "});"
                ]
              }
            }
          ],
          "request": {
            "method": "GET",
            "header": [
              { "key": "Authorization", "value": "Bearer {{accessToken}}" }
            ],
            "url": "{{baseUrl}}/restapi/v2.1/accounts/{{accountId}}/envelopes/{{draftEnvelopeId}}/audit_events"
          }
        },
        {
          "name": "Get Notification Settings",
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "const json = pm.response.json();",
                  "pm.test('Returns notification settings', () => {",
                  "  pm.expect(json.reminders || json.useAccountDefaults).to.exist;",
                  "});"
                ]
              }
            }
          ],
          "request": {
            "method": "GET",
            "header": [
              { "key": "Authorization", "value": "Bearer {{accessToken}}" }
            ],
            "url": "{{baseUrl}}/restapi/v2.1/accounts/{{accountId}}/envelopes/{{draftEnvelopeId}}/notification"
          }
        }
      ]
    },
    {
